{
  "rules": {
    ".read": false,
    ".write": false,

    "syncPins": {
      "$pin": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['pin','shopId','syncVersion']) && newData.child('pin').val() === $pin && newData.child('shopId').isString() && newData.child('shopId').val().length > 0 && newData.child('syncVersion').isNumber()"
      }
    },

    "joinRequests": {
      "$pin": {
        "$requestId": {
          ".read": true,
          ".write": true,
          ".validate": "newData.hasChildren(['clientId','pin']) && newData.child('pin').val() === $pin && newData.child('clientId').isString() && newData.child('clientId').val().length > 0"
        }
      }
    },

    "clientApprovals": {
      "$pin": {
        "$clientId": {
          "$requestId": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChildren(['approved']) && newData.child('approved').isBoolean() && (!newData.child('pin').exists() || newData.child('pin').val() === $pin) && (!newData.child('clientId').exists() || newData.child('clientId').val() === $clientId)"
          }
        }
      }
    },

    "shops": {
      "$shopId": {
        "meta": {
          ".read": true,
          ".write": true,
          ".validate": "newData.hasChildren(['shopId']) && newData.child('shopId').val() === $shopId"
        },
        "messages": {
          "$msgId": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChildren(['type','sentAt']) && newData.child('type').isString() && newData.child('sentAt').isNumber()"
          }
        },
        "operations": {
          "$opId": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChildren(['type']) && newData.child('type').isString()"
          }
        },
        "snapshots": {
          "$version": {
            ".read": true,
            ".write": true,
            ".validate": "!newData.child('shopId').exists() || newData.child('shopId').val() === $shopId"
          }
        },
        "menuImages": {
          "$imageKey": {
            ".read": true,
            ".write": true
          }
        },
        "clients": {
          "$clientId": {
            ".read": true,
            ".write": true,
            ".validate": "!newData.child('clientId').exists() || newData.child('clientId').val() === $clientId"
          }
        },
        "members": {
          "$memberId": {
            ".read": true,
            ".write": true,
            ".validate": "!newData.child('memberId').exists() || newData.child('memberId').val() === $memberId"
          }
        }
      }
    }
  }
}
